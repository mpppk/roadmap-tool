{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && bash .codex/hooks/stop-check.sh",
            "timeout": 120,
            "statusMessage": "Running typecheck/lint/format"
          }
        ]
      }
    ]
  }
}
