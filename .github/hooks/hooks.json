{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "bash": ".github/hooks/post-agent.sh",
        "cwd": ".",
        "timeoutSec": 120
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": ".github/hooks/post-agent.sh",
        "cwd": ".",
        "timeoutSec": 120
      }
    ]
  }
}
