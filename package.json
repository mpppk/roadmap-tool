{
  "name": "roadmap-tool",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "bin": {
    "roadmap-tool": "./src/binary.ts"
  },
  "files": [
    "bunfig.toml",
    "drizzle",
    "src",
    "styles"
  ],
  "scripts": {
    "dev": "ROADMAP_DB=db.sqlite portless run bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "build:binary": "bun run build-binary.ts",
    "typecheck": "bun install --frozen-lockfile && tsc --noEmit",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "check": "biome check ./src",
    "test": "bun test",
    "db:seed": "bun src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/run-migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "playwright-cli": "playwright-cli"
  },
  "dependencies": {
    "@orpc/client": "^1.14.0",
    "@orpc/server": "^1.14.0",
    "@playwright/cli": "^0.1.11",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1",
    "portless": "^0.13.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.11",
    "typescript": "^6.0.3"
  }
}
